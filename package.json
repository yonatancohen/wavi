{
  "name": "wavi",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "WhatsApp AI Group Agent — monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:api": "bash scripts/dev.sh api",
    "dev:dashboard": "bash scripts/dev.sh dashboard",
    "setup": "bash scripts/setup.sh",
    "db:setup": "bash scripts/db-setup.sh",
    "auth:setup": "bash scripts/auth-setup.sh",
    "deploy": "bash scripts/deploy.sh",
    "deploy:prod": "bash scripts/deploy.sh --prod",
    "deploy:quick": "bash scripts/deploy-quick.sh",
    "deploy:quick:prod": "bash scripts/deploy-quick.sh --prod",
    "deploy:quick:api": "bash scripts/deploy-quick.sh --api",
    "deploy:quick:dash": "bash scripts/deploy-quick.sh --dash",
    "deploy:dashboard": "bash scripts/deploy-dashboard.sh",
    "deploy:dashboard:prod": "bash scripts/deploy-dashboard.sh --prod",
    "deploy:api": "bash scripts/deploy-api.sh",
    "deploy:env": "bash scripts/deploy-api.sh --env",
    "sync-secrets": "bash scripts/sync-secrets.sh",
    "sync-secrets:api": "bash scripts/sync-secrets.sh api",
    "sync-secrets:dashboard": "bash scripts/sync-secrets.sh dashboard",
    "preflight": "bash scripts/preflight-deploy.sh",
    "health": "bash scripts/health.sh",
    "health:prod": "bash scripts/health.sh --prod",
    "logs": "bash scripts/logs.sh",
    "ingest:status": "bash scripts/ingest-status.sh",
    "resynthesize:character": "bash scripts/resynthesize-character.sh",
    "rebuild:dynamics": "bash scripts/rebuild-dynamics.sh",
    "regenerate:group-context": "bash scripts/regenerate-group-context.sh",
    "reprofile:from-chunks": "bash scripts/reprofile-from-chunks.sh",
    "merge:colon-profiles": "bash scripts/merge-colon-profiles.sh",
    "test:parser": "bun scripts/test-parser.mjs",
    "test": "bun run --filter '@wavi/api' test",
    "replay": "bun run --filter '@wavi/api' replay",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.9.0",
    "eslint": "10.5.0",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "prettier": "3.8.4",
    "typescript-eslint": "8.61.1"
  }
}
