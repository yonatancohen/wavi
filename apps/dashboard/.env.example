VITE_API_URL=http://localhost:3000/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Only this Google account may sign in (same email as ALLOWED_OWNER_EMAIL in apps/api/.env)
VITE_ALLOWED_OWNER_EMAIL=you@gmail.com

# Skip login for local dev while Supabase Google OAuth is being configured
# VITE_AUTH_DISABLED=true

# Production example (after Railway deploy):
# VITE_API_URL=https://your-app.up.railway.app/api

# Auth setup: run `bun run auth:setup` from the repo root (see docs/AUTH.md).
# That script writes VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY for you.
