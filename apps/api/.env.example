# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dashboard auth setup (used by scripts/auth-setup.sh — not needed at API runtime)
# SUPABASE_ACCESS_TOKEN=sbp_...          # https://supabase.com/dashboard/account/tokens
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings only)
OPENAI_API_KEY=sk-...

# Web search (optional — Tavily; required when a group enables web search)
TAVILY_API_KEY=tvly-...

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Server
PORT=3000
NODE_ENV=development

# Require valid Supabase JWT on API routes (enable in production after OAuth is configured)
# AUTH_REQUIRED=true

# Only this Google account may use the dashboard (must match VITE_ALLOWED_OWNER_EMAIL)
ALLOWED_OWNER_EMAIL=you@gmail.com

# Agent
WA_AGENT_NAME=wavi
AGENT_ID=<your agent row UUID from Supabase>

# Dashboard (production Vercel URL — synced to Railway for CORS; localhost is allowed in code for dev)
# Comma-separated for multiple origins. Production also allows any https://*.vercel.app dashboard deploy.
# Example: https://wavi-fawn.vercel.app (stable Vercel production alias)
DASHBOARD_URL=https://your-app.vercel.app

# Optional extra browser origins (comma-separated)
# CORS_ORIGINS=https://custom.example.com

# WhatsApp session directory (local default; Railway uses /data/.wwebjs_auth with a volume)
# WA_SESSION_PATH=.wwebjs_auth

# Puppeteer CDP timeout for slow Railway Chromium (default 300000 ms / 5 min)
# WA_PROTOCOL_TIMEOUT_MS=300000

# WA health monitor — probes CDP and restarts on stuck/timed-out browser (defaults shown)
# WA_HEALTH_PROBE_INTERVAL_MS=60000
# WA_HEALTH_PROBE_TIMEOUT_MS=8000
# WA_STUCK_OP_MS=45000
# WA_CDP_FAILURE_THRESHOLD=2
# WA_RESTART_COOLDOWN_MS=120000

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
